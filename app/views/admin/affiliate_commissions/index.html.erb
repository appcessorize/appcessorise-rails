<% content_for :title, "Affiliate Commissions - Admin" %>

<h1 class="text-2xl font-bold text-gray-900 mb-2">Affiliate Commissions</h1>

<!-- Summary -->
<div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-6">
  <div class="bg-yellow-50 border border-yellow-200 rounded-xl p-4">
    <p class="text-sm text-yellow-700">Pending</p>
    <p class="text-xl font-bold text-yellow-800">$<%= sprintf("%.2f", @total_pending) %></p>
  </div>
  <div class="bg-blue-50 border border-blue-200 rounded-xl p-4">
    <p class="text-sm text-blue-700">Approved</p>
    <p class="text-xl font-bold text-blue-800">$<%= sprintf("%.2f", @total_approved) %></p>
  </div>
  <div class="bg-green-50 border border-green-200 rounded-xl p-4">
    <p class="text-sm text-green-700">Paid</p>
    <p class="text-xl font-bold text-green-800">$<%= sprintf("%.2f", @total_paid) %></p>
  </div>
</div>

<!-- Filters -->
<div class="flex gap-2 mb-4">
  <%= link_to "All", admin_affiliate_commissions_path, class: "px-3 py-1.5 rounded-lg text-sm font-medium #{params[:status].blank? ? 'bg-gray-900 text-white' : 'bg-white text-gray-700 hover:bg-gray-50'}" %>
  <% %w[pending approved paid].each do |status| %>
    <%= link_to status.titleize, admin_affiliate_commissions_path(status: status), class: "px-3 py-1.5 rounded-lg text-sm font-medium #{params[:status] == status ? 'bg-gray-900 text-white' : 'bg-white text-gray-700 hover:bg-gray-50'}" %>
  <% end %>
</div>

<div class="bg-white rounded-xl shadow-sm overflow-hidden">
  <table class="w-full">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Affiliate</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Order</th>
        <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Rate</th>
        <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Amount</th>
        <th class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase">Status</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Date</th>
        <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Actions</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-100">
      <% @commissions.each do |commission| %>
        <tr class="hover:bg-gray-50">
          <td class="px-6 py-4">
            <%= link_to commission.user.email, admin_user_path(commission.user), class: "text-sm text-blue-600 hover:underline" %>
          </td>
          <td class="px-6 py-4">
            <%= link_to commission.custom_order.order_number, admin_custom_order_path(commission.custom_order), class: "text-sm text-blue-600 hover:underline" %>
          </td>
          <td class="px-6 py-4 text-right text-sm text-gray-600"><%= (commission.commission_rate * 100).round(1) %>%</td>
          <td class="px-6 py-4 text-right font-medium">$<%= sprintf("%.2f", commission.commission_amount) %></td>
          <td class="px-6 py-4 text-center">
            <span class="px-2 py-0.5 rounded text-xs font-medium
              <%= case commission.status
                  when 'paid' then 'bg-green-100 text-green-700'
                  when 'approved' then 'bg-blue-100 text-blue-700'
                  when 'pending' then 'bg-yellow-100 text-yellow-700'
                  end %>">
              <%= commission.status %>
            </span>
          </td>
          <td class="px-6 py-4 text-sm text-gray-500"><%= commission.created_at.strftime("%b %d, %Y") %></td>
          <td class="px-6 py-4 text-right">
            <% if commission.status == "pending" %>
              <%= button_to "Approve", approve_admin_affiliate_commission_path(commission), method: :patch, class: "text-xs px-2 py-1 bg-blue-600 text-white rounded hover:bg-blue-700 cursor-pointer" %>
            <% elsif commission.status == "approved" %>
              <%= button_to "Mark Paid", pay_admin_affiliate_commission_path(commission), method: :patch, class: "text-xs px-2 py-1 bg-green-600 text-white rounded hover:bg-green-700 cursor-pointer" %>
            <% elsif commission.paid_at %>
              <span class="text-xs text-gray-500">Paid <%= commission.paid_at.strftime("%b %d") %></span>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
  <% if @commissions.empty? %>
    <p class="px-6 py-8 text-center text-gray-500">No commissions found.</p>
  <% end %>
</div>
<div class="mt-4 flex justify-center"><%== pagy_nav(@pagy) %></div>
