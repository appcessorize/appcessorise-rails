<% content_for :title, "Users - Admin" %>

<div class="flex justify-between items-center mb-6">
  <h1 class="text-2xl font-bold text-gray-900">Users</h1>
  <div class="flex gap-2">
    <%= link_to "All", admin_users_path, class: "px-3 py-1.5 rounded-lg text-sm font-medium #{params[:role].blank? ? 'bg-gray-900 text-white' : 'bg-white text-gray-700 hover:bg-gray-50'}" %>
    <% %w[customer affiliate admin].each do |role| %>
      <%= link_to role.titleize, admin_users_path(role: role), class: "px-3 py-1.5 rounded-lg text-sm font-medium #{params[:role] == role ? 'bg-gray-900 text-white' : 'bg-white text-gray-700 hover:bg-gray-50'}" %>
    <% end %>
  </div>
</div>

<div class="bg-white rounded-xl shadow-sm overflow-hidden">
  <table class="w-full">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">ID</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Email</th>
        <th class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase">Role</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Affiliate Code</th>
        <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Commissions</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Joined</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-100">
      <% @users.each do |user| %>
        <tr class="hover:bg-gray-50 cursor-pointer" onclick="window.location='<%= admin_user_path(user) %>'">
          <td class="px-6 py-4 text-sm text-gray-600"><%= user.id %></td>
          <td class="px-6 py-4 font-medium text-gray-900"><%= user.email %></td>
          <td class="px-6 py-4 text-center">
            <span class="px-2 py-0.5 rounded text-xs font-medium
              <%= case user.role
                  when 'admin' then 'bg-purple-100 text-purple-700'
                  when 'affiliate' then 'bg-blue-100 text-blue-700'
                  else 'bg-gray-100 text-gray-600'
                  end %>">
              <%= user.role %>
            </span>
          </td>
          <td class="px-6 py-4 text-sm text-gray-600 font-mono"><%= user.affiliate_code || "-" %></td>
          <td class="px-6 py-4 text-right text-sm">
            <% if user.affiliate? || user.admin? %>
              $<%= sprintf("%.2f", user.total_commissions) %>
            <% else %>
              -
            <% end %>
          </td>
          <td class="px-6 py-4 text-sm text-gray-500"><%= user.created_at.strftime("%b %d, %Y") %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
  <% if @users.empty? %>
    <p class="px-6 py-8 text-center text-gray-500">No users found.</p>
  <% end %>
</div>
