<% content_for :title, "#{@user.email} - Admin" %>

<%= link_to "&larr; Back to Users".html_safe, admin_users_path, class: "text-sm text-blue-600 hover:underline" %>

<div class="mt-4 bg-white rounded-xl shadow-sm p-6">
  <div class="flex justify-between items-start mb-6">
    <div>
      <h1 class="text-2xl font-bold text-gray-900"><%= @user.email %></h1>
      <p class="text-sm text-gray-500">Joined <%= @user.created_at.strftime("%B %d, %Y") %></p>
    </div>
    <span class="px-3 py-1 rounded-lg text-sm font-semibold
      <%= case @user.role
          when 'admin' then 'bg-purple-100 text-purple-700'
          when 'affiliate' then 'bg-blue-100 text-blue-700'
          else 'bg-gray-100 text-gray-600'
          end %>">
      <%= @user.role.titleize %>
    </span>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6 text-sm">
    <div class="bg-gray-50 rounded-lg p-4">
      <p class="text-gray-500">Affiliate Code</p>
      <p class="font-mono font-medium text-gray-900"><%= @user.affiliate_code || "N/A" %></p>
    </div>
    <div class="bg-gray-50 rounded-lg p-4">
      <p class="text-gray-500">Total Commissions</p>
      <p class="font-medium text-gray-900">$<%= sprintf("%.2f", @user.total_commissions) %></p>
    </div>
    <div class="bg-gray-50 rounded-lg p-4">
      <p class="text-gray-500">Unpaid Commissions</p>
      <p class="font-medium text-orange-600">$<%= sprintf("%.2f", @user.unpaid_commissions) %></p>
    </div>
  </div>

  <!-- Role change -->
  <div class="bg-gray-50 rounded-lg p-4 mb-6">
    <h3 class="font-semibold text-gray-800 mb-3">Change Role</h3>
    <%= form_with model: @user, url: admin_user_path(@user), method: :patch, class: "flex items-center gap-3" do |f| %>
      <%= f.select :role, User.roles.keys.map { |r| [r.titleize, r] }, {}, class: "select select-bordered select-sm" %>
      <%= f.submit "Update", class: "px-4 py-1.5 bg-gray-900 text-white text-sm font-medium rounded-lg hover:bg-gray-800 cursor-pointer" %>
    <% end %>
  </div>

  <!-- Account Status -->
  <div class="text-sm text-gray-500 space-y-1">
    <p>Failed login attempts: <%= @user.failed_attempts %></p>
    <% if @user.locked_at %>
      <p class="text-red-600">Account locked at: <%= @user.locked_at.strftime("%B %d, %Y %I:%M %p") %></p>
    <% end %>
  </div>
</div>
