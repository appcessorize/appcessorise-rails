<% content_for :title, "Order ##{@order.id} - Admin" %>

<%= link_to "&larr; Back to Orders".html_safe, admin_orders_path, class: "text-sm text-blue-600 hover:underline" %>

<div class="mt-4 bg-white rounded-xl shadow-sm p-6">
  <div class="flex justify-between items-start mb-6">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Order #<%= @order.id %></h1>
      <p class="text-sm text-gray-500"><%= @order.created_at.strftime("%B %d, %Y at %I:%M %p") %></p>
    </div>
    <span class="px-3 py-1 rounded-lg text-sm font-semibold
      <%= case @order.status
          when 'paid', 'completed' then 'bg-green-100 text-green-700'
          when 'pending', 'processing' then 'bg-yellow-100 text-yellow-700'
          when 'failed', 'cancelled' then 'bg-red-100 text-red-700'
          when 'refunded' then 'bg-gray-100 text-gray-700'
          else 'bg-gray-100 text-gray-600'
          end %>">
      <%= @order.status.titleize %>
    </span>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6 text-sm">
    <div class="bg-gray-50 rounded-lg p-4">
      <p class="text-gray-500">Customer</p>
      <% if @order.user %>
        <%= link_to @order.user.email, admin_user_path(@order.user), class: "font-medium text-blue-600 hover:underline" %>
      <% else %>
        <p class="font-medium text-gray-900">Guest checkout</p>
      <% end %>
    </div>
    <div class="bg-gray-50 rounded-lg p-4">
      <p class="text-gray-500">Stripe Payment Intent</p>
      <p class="font-mono text-xs text-gray-900 break-all"><%= @order.stripe_payment_intent_id || "N/A" %></p>
    </div>
    <div class="bg-gray-50 rounded-lg p-4">
      <p class="text-gray-500">Currency</p>
      <p class="font-medium text-gray-900"><%= @order.currency.upcase %></p>
    </div>
  </div>

  <h2 class="font-semibold text-gray-900 mb-3">Items</h2>
  <div class="border border-gray-200 rounded-lg overflow-hidden mb-6">
    <table class="w-full">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">Product</th>
          <th class="px-4 py-2 text-right text-xs font-medium text-gray-500 uppercase">Qty</th>
          <th class="px-4 py-2 text-right text-xs font-medium text-gray-500 uppercase">Price</th>
          <th class="px-4 py-2 text-right text-xs font-medium text-gray-500 uppercase">Total</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% @order.order_items.each do |item| %>
          <tr>
            <td class="px-4 py-3 text-gray-900"><%= item.product_name %></td>
            <td class="px-4 py-3 text-right text-gray-600"><%= item.quantity %></td>
            <td class="px-4 py-3 text-right text-gray-600">$<%= sprintf("%.2f", item.price) %></td>
            <td class="px-4 py-3 text-right font-medium text-gray-900">$<%= sprintf("%.2f", item.total) %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <div class="flex justify-end">
    <div class="bg-gray-50 rounded-lg p-4 w-64">
      <div class="flex justify-between text-lg font-bold text-gray-900">
        <span>Total</span>
        <span>$<%= sprintf("%.2f", @order.amount) %></span>
      </div>
    </div>
  </div>
</div>
