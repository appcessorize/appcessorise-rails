<% content_for :title, "Premium Phone Case - Appcessorise" %>

<div class="min-h-screen bg-white">
  <%= render 'shared/navigation' %>

  <div class="mx-auto max-w-[1400px] px-4 sm:px-6 lg:px-12 pt-8 pb-16 lg:pb-24">

    <!-- Product Layout: Gallery + Info -->
    <div class="flex flex-col lg:grid lg:grid-cols-[80px_1fr_1fr] lg:gap-8 xl:gap-10" data-controller="product-gallery">

      <!-- Thumbnails (vertical column) -->
      <div class="order-1 flex lg:flex-col gap-2 mb-4 lg:mb-0 overflow-x-auto lg:overflow-visible">
        <button type="button" data-product-gallery-target="thumbnail" data-index="0" data-action="click->product-gallery#select"
                class="shrink-0 w-[72px] h-[72px] lg:w-full lg:h-auto lg:aspect-square overflow-hidden rounded bg-[#f5f5f5] ring-2 ring-[#1a1a1a] cursor-pointer transition">
          <div class="flex h-full items-center justify-center">
            <div class="w-full h-full bg-[#f5f5f5]"></div>
          </div>
        </button>
        <button type="button" data-product-gallery-target="thumbnail" data-index="1" data-action="click->product-gallery#select"
                class="shrink-0 w-[72px] h-[72px] lg:w-full lg:h-auto lg:aspect-square overflow-hidden rounded bg-[#f5f5f5] ring-1 ring-[#e5e5e5] cursor-pointer hover:ring-[#999] transition">
          <div class="flex h-full items-center justify-center">
            <div class="w-full h-full bg-[#f0f0f0]"></div>
          </div>
        </button>
        <button type="button" data-product-gallery-target="thumbnail" data-index="2" data-action="click->product-gallery#select"
                class="shrink-0 w-[72px] h-[72px] lg:w-full lg:h-auto lg:aspect-square overflow-hidden rounded bg-[#f5f5f5] ring-1 ring-[#e5e5e5] cursor-pointer hover:ring-[#999] transition">
          <div class="flex h-full items-center justify-center">
            <div class="w-full h-full bg-[#f2f2f2]"></div>
          </div>
        </button>
        <button type="button" data-product-gallery-target="thumbnail" data-index="3" data-action="click->product-gallery#select"
                class="shrink-0 w-[72px] h-[72px] lg:w-full lg:h-auto lg:aspect-square overflow-hidden rounded bg-[#f5f5f5] ring-1 ring-[#e5e5e5] cursor-pointer hover:ring-[#999] transition">
          <div class="flex h-full items-center justify-center">
            <div class="w-full h-full bg-[#efefef]"></div>
          </div>
        </button>
        <button type="button" data-product-gallery-target="thumbnail" data-index="4" data-action="click->product-gallery#select"
                class="shrink-0 w-[72px] h-[72px] lg:w-full lg:h-auto lg:aspect-square overflow-hidden rounded bg-[#f5f5f5] ring-1 ring-[#e5e5e5] cursor-pointer hover:ring-[#999] transition">
          <div class="flex h-full items-center justify-center">
            <div class="w-full h-full bg-[#f3f3f3]"></div>
          </div>
        </button>
        <button type="button" data-product-gallery-target="thumbnail" data-index="5" data-action="click->product-gallery#select"
                class="shrink-0 w-[72px] h-[72px] lg:w-full lg:h-auto lg:aspect-square overflow-hidden rounded bg-[#f5f5f5] ring-1 ring-[#e5e5e5] cursor-pointer hover:ring-[#999] transition">
          <div class="flex h-full items-center justify-center">
            <div class="w-full h-full bg-[#f1f1f1]"></div>
          </div>
        </button>
      </div>

      <!-- Main Image -->
      <div class="order-2 mb-8 lg:mb-0">
        <div data-product-gallery-target="mainImage" class="w-full aspect-[4/5] bg-[#f2f2f2] rounded flex items-center justify-center">
          <div class="w-3/4 h-3/4 bg-[#e8e8e8] rounded"></div>
        </div>
        <div data-product-gallery-target="mainImage" class="hidden w-full aspect-[4/5] bg-[#f0f0f0] rounded flex items-center justify-center">
          <div class="w-3/4 h-3/4 bg-[#e5e5e5] rounded"></div>
        </div>
        <div data-product-gallery-target="mainImage" class="hidden w-full aspect-[4/5] bg-[#f2f2f2] rounded flex items-center justify-center">
          <div class="w-3/4 h-3/4 bg-[#e6e6e6] rounded"></div>
        </div>
        <div data-product-gallery-target="mainImage" class="hidden w-full aspect-[4/5] bg-[#f1f1f1] rounded flex items-center justify-center">
          <div class="w-3/4 h-3/4 bg-[#e7e7e7] rounded"></div>
        </div>
        <div data-product-gallery-target="mainImage" class="hidden w-full aspect-[4/5] bg-[#f3f3f3] rounded flex items-center justify-center">
          <div class="w-3/4 h-3/4 bg-[#e9e9e9] rounded"></div>
        </div>
        <div data-product-gallery-target="mainImage" class="hidden w-full aspect-[4/5] bg-[#f0f0f0] rounded flex items-center justify-center">
          <div class="w-3/4 h-3/4 bg-[#e4e4e4] rounded"></div>
        </div>
      </div>

      <!-- Product Info -->
      <div class="order-3 lg:pl-4">

        <!-- Title + Price row -->
        <div class="flex items-baseline justify-between gap-4">
          <h1 class="text-[26px] lg:text-[34px] leading-tight" style="font-family: 'Playfair Display', serif; font-style: italic;">
            Smart LED Desk Lamp
          </h1>
          <span class="text-[20px] lg:text-[24px] text-[#d4542b] shrink-0" style="font-family: 'Playfair Display', serif; font-style: italic;">
            $29.99
          </span>
        </div>

        <!-- Description -->
        <p class="mt-5 text-[15px] lg:text-[17px] leading-relaxed text-[#777]">
          Illuminate your workspace with the Smart LED Desk Lamp. Featuring adjustable brightness, color temperature, and voice control, it's the perfect addition to any modern office or home setup.
        </p>

        <!-- Tags -->
        <div class="mt-5 flex items-center gap-4">
          <span class="text-[13px] font-medium text-[#1a1a1a] tracking-wide">Desktop</span>
          <span class="text-[13px] font-medium text-[#1a1a1a] tracking-wide">Accessories</span>
          <span class="text-[13px] font-medium text-[#1a1a1a] tracking-wide">Season</span>
        </div>

        <!-- Purchase Button -->
        <div class="mt-7">
          <%= link_to new_checkout_path(quantity: 1), class: "inline-flex items-center justify-center px-8 py-3 bg-[#1a1a1a] text-white text-[14px] font-medium rounded-full hover:bg-[#333] active:translate-y-[0.5px] transition" do %>
            Purchase
          <% end %>
        </div>

        <!-- Tabs Section -->
        <div class="mt-10" data-controller="product-tabs">

          <!-- Tab Headers -->
          <div class="flex gap-6 border-b border-[#e5e5e5]">
            <button type="button" data-product-tabs-target="tab" data-index="0" data-action="click->product-tabs#select"
                    class="pb-3 text-[14px] font-medium border-b-2 border-[#1a1a1a] text-[#1a1a1a] cursor-pointer transition">
              Details
            </button>
            <button type="button" data-product-tabs-target="tab" data-index="1" data-action="click->product-tabs#select"
                    class="pb-3 text-[14px] font-medium border-b-2 border-transparent text-[#999] cursor-pointer hover:text-[#666] transition">
              Shipping
            </button>
            <button type="button" data-product-tabs-target="tab" data-index="2" data-action="click->product-tabs#select"
                    class="pb-3 text-[14px] font-medium border-b-2 border-transparent text-[#999] cursor-pointer hover:text-[#666] transition">
              Returns
            </button>
            <button type="button" data-product-tabs-target="tab" data-index="3" data-action="click->product-tabs#select"
                    class="pb-3 text-[14px] font-medium border-b-2 border-transparent text-[#999] cursor-pointer hover:text-[#666] transition">
              Reviews
            </button>
          </div>

          <!-- Tab: Details -->
          <div data-product-tabs-target="panel" class="pt-8">
            <p class="text-[16px] leading-[1.7] text-[#555]">
              This product is crafted from high-quality materials designed for durability and comfort. It features modern design elements and is perfect for everyday use.
            </p>
            <ul class="mt-6 space-y-3">
              <li class="flex items-start gap-3 text-[15px] text-[#555]">
                <span class="mt-2 w-1.5 h-1.5 rounded-full bg-[#555] shrink-0"></span>
                Adjustable brightness and color temperature
              </li>
              <li class="flex items-start gap-3 text-[15px] text-[#555]">
                <span class="mt-2 w-1.5 h-1.5 rounded-full bg-[#555] shrink-0"></span>
                Voice control with Alexa and Google Assistant
              </li>
              <li class="flex items-start gap-3 text-[15px] text-[#555]">
                <span class="mt-2 w-1.5 h-1.5 rounded-full bg-[#555] shrink-0"></span>
                Sleek and space-saving design
              </li>
              <li class="flex items-start gap-3 text-[15px] text-[#555]">
                <span class="mt-2 w-1.5 h-1.5 rounded-full bg-[#555] shrink-0"></span>
                Touch-sensitive control panel
              </li>
              <li class="flex items-start gap-3 text-[15px] text-[#555]">
                <span class="mt-2 w-1.5 h-1.5 rounded-full bg-[#555] shrink-0"></span>
                Energy-efficient LED technology
              </li>
              <li class="flex items-start gap-3 text-[15px] text-[#555]">
                <span class="mt-2 w-1.5 h-1.5 rounded-full bg-[#555] shrink-0"></span>
                Perfect for reading, working, and relaxing
              </li>
              <li class="flex items-start gap-3 text-[15px] text-[#555]">
                <span class="mt-2 w-1.5 h-1.5 rounded-full bg-[#555] shrink-0"></span>
                Built-in USB charging port
              </li>
              <li class="flex items-start gap-3 text-[15px] text-[#555]">
                <span class="mt-2 w-1.5 h-1.5 rounded-full bg-[#555] shrink-0"></span>
                Auto shut-off timer for energy saving
              </li>
            </ul>
          </div>

          <!-- Tab: Shipping -->
          <div data-product-tabs-target="panel" class="hidden pt-8">
            <p class="text-[16px] leading-[1.7] text-[#555]">
              We offer free standard shipping on all orders over $50. Standard delivery takes 5-7 business days. Express shipping is available at checkout for an additional fee, with delivery in 2-3 business days.
            </p>
            <ul class="mt-6 space-y-3">
              <li class="flex items-start gap-3 text-[15px] text-[#555]">
                <span class="mt-2 w-1.5 h-1.5 rounded-full bg-[#555] shrink-0"></span>
                Free standard shipping on orders over $50
              </li>
              <li class="flex items-start gap-3 text-[15px] text-[#555]">
                <span class="mt-2 w-1.5 h-1.5 rounded-full bg-[#555] shrink-0"></span>
                Express shipping: 2-3 business days
              </li>
              <li class="flex items-start gap-3 text-[15px] text-[#555]">
                <span class="mt-2 w-1.5 h-1.5 rounded-full bg-[#555] shrink-0"></span>
                International shipping available
              </li>
            </ul>
          </div>

          <!-- Tab: Returns -->
          <div data-product-tabs-target="panel" class="hidden pt-8">
            <p class="text-[16px] leading-[1.7] text-[#555]">
              We accept returns within 30 days of purchase. Items must be in their original condition with all packaging included. Once we receive your return, we'll process your refund within 5-7 business days.
            </p>
          </div>

          <!-- Tab: Reviews -->
          <div data-product-tabs-target="panel" class="hidden pt-8">
            <p class="text-[16px] leading-[1.7] text-[#555]">
              No reviews yet. Be the first to review this product.
            </p>
          </div>

        </div>
      </div>

    </div>
  </div>
</div>
