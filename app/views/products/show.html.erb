<% content_for :title, "Premium Phone Case - Appcessorise" %>

<div class="min-h-screen bg-white">
  <%= render 'shared/navigation' %>

  <div class="mx-auto max-w-[1200px] px-4 sm:px-6 lg:px-10 pt-6 pb-16 lg:pb-24">

    <!-- Breadcrumb -->
    <nav aria-label="Breadcrumb" class="mb-8">
      <ol role="list" class="flex items-center gap-2 text-sm text-[oklch(55%_0_0)]">
        <li><%= link_to "Home", root_path, class: "hover:text-[oklch(21%_0.006_285.885)] transition" %></li>
        <li><span class="text-[oklch(75%_0_0)]">/</span></li>
        <li><%= link_to "Products", products_path, class: "hover:text-[oklch(21%_0.006_285.885)] transition" %></li>
        <li><span class="text-[oklch(75%_0_0)]">/</span></li>
        <li class="text-[oklch(21%_0.006_285.885)]" aria-current="page">Premium Phone Case</li>
      </ol>
    </nav>

    <!-- Two-Column Product Layout -->
    <div class="lg:grid lg:grid-cols-[1fr_420px] lg:gap-12 xl:gap-16" data-controller="product-gallery">

      <!-- LEFT: Image Gallery -->
      <div class="lg:order-1">
        <!-- Main Image -->
        <div class="relative mb-3">
          <div data-product-gallery-target="mainImage" class="aspect-square w-full overflow-hidden rounded-lg bg-gradient-to-br from-[oklch(94%_0.02_260)] to-[oklch(90%_0.03_260)] border border-[oklch(92%_0_0)]">
            <div class="flex h-full items-center justify-center">
              <span class="text-[120px] leading-none">📱</span>
            </div>
          </div>
          <div data-product-gallery-target="mainImage" class="hidden aspect-square w-full overflow-hidden rounded-lg bg-gradient-to-br from-[oklch(94%_0.03_300)] to-[oklch(88%_0.04_300)] border border-[oklch(92%_0_0)]">
            <div class="flex h-full items-center justify-center">
              <span class="text-[120px] leading-none">📱</span>
            </div>
          </div>
          <div data-product-gallery-target="mainImage" class="hidden aspect-square w-full overflow-hidden rounded-lg bg-gradient-to-br from-[oklch(96%_0.01_80)] to-[oklch(92%_0.02_80)] border border-[oklch(92%_0_0)]">
            <div class="flex h-full items-center justify-center">
              <span class="text-[120px] leading-none">📱</span>
            </div>
          </div>
          <div data-product-gallery-target="mainImage" class="hidden aspect-square w-full overflow-hidden rounded-lg bg-gradient-to-br from-[oklch(94%_0.01_200)] to-[oklch(90%_0.02_200)] border border-[oklch(92%_0_0)]">
            <div class="flex h-full items-center justify-center">
              <span class="text-[120px] leading-none">📱</span>
            </div>
          </div>
        </div>

        <!-- Thumbnails -->
        <div class="grid grid-cols-4 gap-3">
          <button type="button" data-product-gallery-target="thumbnail" data-index="0" data-action="click->product-gallery#select" class="aspect-square overflow-hidden rounded-md bg-gradient-to-br from-[oklch(94%_0.02_260)] to-[oklch(90%_0.03_260)] ring-2 ring-[oklch(14%_0.005_285.823)] cursor-pointer transition">
            <div class="flex h-full items-center justify-center">
              <span class="text-3xl">📱</span>
            </div>
          </button>
          <button type="button" data-product-gallery-target="thumbnail" data-index="1" data-action="click->product-gallery#select" class="aspect-square overflow-hidden rounded-md bg-gradient-to-br from-[oklch(94%_0.03_300)] to-[oklch(88%_0.04_300)] ring-1 ring-[oklch(88%_0_0)] cursor-pointer hover:ring-[oklch(60%_0_0)] transition">
            <div class="flex h-full items-center justify-center">
              <span class="text-3xl">📱</span>
            </div>
          </button>
          <button type="button" data-product-gallery-target="thumbnail" data-index="2" data-action="click->product-gallery#select" class="aspect-square overflow-hidden rounded-md bg-gradient-to-br from-[oklch(96%_0.01_80)] to-[oklch(92%_0.02_80)] ring-1 ring-[oklch(88%_0_0)] cursor-pointer hover:ring-[oklch(60%_0_0)] transition">
            <div class="flex h-full items-center justify-center">
              <span class="text-3xl">📱</span>
            </div>
          </button>
          <button type="button" data-product-gallery-target="thumbnail" data-index="3" data-action="click->product-gallery#select" class="aspect-square overflow-hidden rounded-md bg-gradient-to-br from-[oklch(94%_0.01_200)] to-[oklch(90%_0.02_200)] ring-1 ring-[oklch(88%_0_0)] cursor-pointer hover:ring-[oklch(60%_0_0)] transition">
            <div class="flex h-full items-center justify-center">
              <span class="text-3xl">📱</span>
            </div>
          </button>
        </div>
      </div>

      <!-- RIGHT: Product Info (Sticky) -->
      <div class="mt-10 lg:mt-0 lg:order-2 lg:sticky lg:top-8 lg:self-start">

        <!-- Title -->
        <h1 class="text-[28px] lg:text-[32px] font-normal leading-tight text-[oklch(21%_0.006_285.885)]">
          Premium Phone Case
        </h1>

        <% if @custom_text.present? %>
          <div class="mt-3 px-4 py-3 bg-[oklch(96%_0.01_260)] border border-[oklch(88%_0.02_260)] rounded-lg">
            <p class="text-sm font-medium text-[oklch(30%_0.02_260)]">Custom Text: <%= @custom_text %></p>
          </div>
        <% end %>

        <!-- Price -->
        <div class="mt-4">
          <span class="text-[22px] tracking-tight text-[oklch(21%_0.006_285.885)]">$29.99</span>
        </div>

        <!-- Divider -->
        <hr class="my-6 border-[oklch(92%_0_0)]">

        <form>
          <!-- Color -->
          <div>
            <p class="text-sm text-[oklch(21%_0.006_285.885)] mb-3">
              Color: <span class="text-[oklch(45%_0_0)]">Blue</span>
            </p>
            <fieldset aria-label="Choose a color" class="flex items-center gap-3">
              <label class="relative cursor-pointer">
                <input type="radio" name="color" value="blue" checked class="sr-only peer" />
                <span class="block h-9 w-9 rounded-full bg-[oklch(52%_0.18_260)] peer-checked:ring-2 peer-checked:ring-offset-2 peer-checked:ring-[oklch(21%_0.006_285.885)] transition"></span>
              </label>
              <label class="relative cursor-pointer">
                <input type="radio" name="color" value="purple" class="sr-only peer" />
                <span class="block h-9 w-9 rounded-full bg-[oklch(52%_0.18_300)] peer-checked:ring-2 peer-checked:ring-offset-2 peer-checked:ring-[oklch(21%_0.006_285.885)] hover:ring-1 hover:ring-offset-1 hover:ring-[oklch(70%_0_0)] transition"></span>
              </label>
              <label class="relative cursor-pointer">
                <input type="radio" name="color" value="black" class="sr-only peer" />
                <span class="block h-9 w-9 rounded-full bg-[oklch(21%_0_0)] peer-checked:ring-2 peer-checked:ring-offset-2 peer-checked:ring-[oklch(21%_0.006_285.885)] hover:ring-1 hover:ring-offset-1 hover:ring-[oklch(70%_0_0)] transition"></span>
              </label>
            </fieldset>
          </div>

          <!-- Model -->
          <div class="mt-6">
            <p class="text-sm text-[oklch(21%_0.006_285.885)] mb-3">Model</p>
            <fieldset aria-label="Choose a model" class="flex flex-wrap gap-2">
              <label class="cursor-pointer">
                <input type="radio" name="model" value="iphone-14" class="sr-only peer" />
                <span class="inline-flex items-center px-4 py-2.5 text-sm border border-[oklch(85%_0_0)] rounded-full peer-checked:border-[oklch(14%_0.005_285.823)] peer-checked:bg-[oklch(14%_0.005_285.823)] peer-checked:text-white hover:border-[oklch(60%_0_0)] transition">
                  iPhone 14
                </span>
              </label>
              <label class="cursor-pointer">
                <input type="radio" name="model" value="iphone-14-pro" checked class="sr-only peer" />
                <span class="inline-flex items-center px-4 py-2.5 text-sm border border-[oklch(85%_0_0)] rounded-full peer-checked:border-[oklch(14%_0.005_285.823)] peer-checked:bg-[oklch(14%_0.005_285.823)] peer-checked:text-white hover:border-[oklch(60%_0_0)] transition">
                  iPhone 14 Pro
                </span>
              </label>
              <label class="cursor-pointer">
                <input type="radio" name="model" value="iphone-15" class="sr-only peer" />
                <span class="inline-flex items-center px-4 py-2.5 text-sm border border-[oklch(85%_0_0)] rounded-full peer-checked:border-[oklch(14%_0.005_285.823)] peer-checked:bg-[oklch(14%_0.005_285.823)] peer-checked:text-white hover:border-[oklch(60%_0_0)] transition">
                  iPhone 15
                </span>
              </label>
              <label class="cursor-pointer">
                <input type="radio" name="model" value="iphone-15-pro" class="sr-only peer" />
                <span class="inline-flex items-center px-4 py-2.5 text-sm border border-[oklch(85%_0_0)] rounded-full peer-checked:border-[oklch(14%_0.005_285.823)] peer-checked:bg-[oklch(14%_0.005_285.823)] peer-checked:text-white hover:border-[oklch(60%_0_0)] transition">
                  iPhone 15 Pro
                </span>
              </label>
            </fieldset>
          </div>

          <!-- Add to Cart -->
          <%= link_to new_checkout_path(quantity: 1), class: "btn-primary-daisy w-full mt-8" do %>
            Add to cart
          <% end %>

          <!-- Buy it now -->
          <%= link_to new_checkout_path(quantity: 1), class: "btn-secondary-daisy w-full mt-3" do %>
            Buy it now
          <% end %>
        </form>

        <!-- Trust Badges -->
        <div class="mt-6 space-y-3">
          <div class="flex items-center gap-3 text-sm text-[oklch(40%_0_0)]">
            <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0H21M3.375 14.25V3.375c0-.621.504-1.125 1.125-1.125h9.75c.621 0 1.125.504 1.125 1.125v4.5m3 6.75V10.5a2.25 2.25 0 00-2.25-2.25h-1.5a2.25 2.25 0 00-2.25 2.25v6" />
            </svg>
            <span>Free shipping on orders over $50</span>
          </div>
          <div class="flex items-center gap-3 text-sm text-[oklch(40%_0_0)]">
            <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
            </svg>
            <span>Secure checkout</span>
          </div>
          <div class="flex items-center gap-3 text-sm text-[oklch(40%_0_0)]">
            <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182M2.985 19.644l3.181-3.183" />
            </svg>
            <span>Free returns within 30 days</span>
          </div>
        </div>

        <!-- Divider -->
        <hr class="my-6 border-[oklch(92%_0_0)]">

        <!-- Accordion Sections -->
        <div class="divide-y divide-[oklch(92%_0_0)]">

          <!-- Description -->
          <details open class="group">
            <summary class="flex w-full items-center justify-between py-4 text-left cursor-pointer">
              <span class="text-sm font-medium text-[oklch(21%_0.006_285.885)]">Description</span>
              <svg class="w-5 h-5 text-[oklch(55%_0_0)] transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
              </svg>
            </summary>
            <div class="pb-4 text-sm text-[oklch(40%_0_0)] leading-relaxed space-y-3">
              <p>Experience ultimate protection without sacrificing style. Our Premium Phone Case combines military-grade drop protection with a sleek, minimalist design that complements your device perfectly.</p>
              <p>Crafted from high-quality materials with precision-engineered air pockets, this case absorbs impact while maintaining a slim profile. The raised bezels protect your screen and camera, while the responsive buttons provide tactile feedback.</p>
            </div>
          </details>

          <!-- Key Features -->
          <details class="group">
            <summary class="flex w-full items-center justify-between py-4 text-left cursor-pointer">
              <span class="text-sm font-medium text-[oklch(21%_0.006_285.885)]">Key Features</span>
              <svg class="w-5 h-5 text-[oklch(55%_0_0)] transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
              </svg>
            </summary>
            <div class="pb-4">
              <ul class="space-y-3 text-sm text-[oklch(40%_0_0)]">
                <li class="flex items-start gap-3">
                  <svg class="w-4 h-4 mt-0.5 shrink-0 text-[oklch(21%_0.006_285.885)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.5 12.75l6 6 9-13.5" />
                  </svg>
                  <span><strong class="text-[oklch(21%_0.006_285.885)]">Military-Grade Protection</strong> &mdash; Tested to withstand drops from up to 12 feet</span>
                </li>
                <li class="flex items-start gap-3">
                  <svg class="w-4 h-4 mt-0.5 shrink-0 text-[oklch(21%_0.006_285.885)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.5 12.75l6 6 9-13.5" />
                  </svg>
                  <span><strong class="text-[oklch(21%_0.006_285.885)]">Wireless Charging</strong> &mdash; Fully compatible with all Qi chargers</span>
                </li>
                <li class="flex items-start gap-3">
                  <svg class="w-4 h-4 mt-0.5 shrink-0 text-[oklch(21%_0.006_285.885)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.5 12.75l6 6 9-13.5" />
                  </svg>
                  <span><strong class="text-[oklch(21%_0.006_285.885)]">Raised Bezels</strong> &mdash; Extra protection for screen and camera</span>
                </li>
                <li class="flex items-start gap-3">
                  <svg class="w-4 h-4 mt-0.5 shrink-0 text-[oklch(21%_0.006_285.885)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.5 12.75l6 6 9-13.5" />
                  </svg>
                  <span><strong class="text-[oklch(21%_0.006_285.885)]">Slim Design</strong> &mdash; Only 2mm thin, fits in your pocket</span>
                </li>
              </ul>
            </div>
          </details>

          <!-- What's Included -->
          <details class="group">
            <summary class="flex w-full items-center justify-between py-4 text-left cursor-pointer">
              <span class="text-sm font-medium text-[oklch(21%_0.006_285.885)]">What's Included</span>
              <svg class="w-5 h-5 text-[oklch(55%_0_0)] transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
              </svg>
            </summary>
            <div class="pb-4">
              <ul class="space-y-2 text-sm text-[oklch(40%_0_0)]">
                <li class="flex items-center gap-2">
                  <span class="w-1 h-1 rounded-full bg-[oklch(55%_0_0)]"></span>
                  Premium Phone Case
                </li>
                <li class="flex items-center gap-2">
                  <span class="w-1 h-1 rounded-full bg-[oklch(55%_0_0)]"></span>
                  Microfiber cleaning cloth
                </li>
                <li class="flex items-center gap-2">
                  <span class="w-1 h-1 rounded-full bg-[oklch(55%_0_0)]"></span>
                  Screen protector installation kit
                </li>
                <li class="flex items-center gap-2">
                  <span class="w-1 h-1 rounded-full bg-[oklch(55%_0_0)]"></span>
                  1-year warranty certificate
                </li>
              </ul>
            </div>
          </details>

          <!-- Warranty -->
          <details class="group">
            <summary class="flex w-full items-center justify-between py-4 text-left cursor-pointer">
              <span class="text-sm font-medium text-[oklch(21%_0.006_285.885)]">Warranty</span>
              <svg class="w-5 h-5 text-[oklch(55%_0_0)] transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
              </svg>
            </summary>
            <div class="pb-4 text-sm text-[oklch(40%_0_0)] leading-relaxed">
              <p>We stand behind our products with a <strong class="text-[oklch(21%_0.006_285.885)]">1-Year Warranty</strong>. If anything goes wrong within the first year, we'll replace it for free. No questions asked.</p>
            </div>
          </details>

        </div>
      </div>

    </div>
  </div>
</div>
