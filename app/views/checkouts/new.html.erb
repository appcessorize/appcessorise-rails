<% content_for :title, "Checkout - Appcessorise" %>

<div class="min-h-screen bg-white">
  <%= render 'shared/navigation' %>

  <div class="mx-auto max-w-[1200px] px-4 sm:px-6 lg:px-10 pt-6 pb-16 lg:pb-24">

    <!-- Breadcrumb -->
    <nav aria-label="Breadcrumb" class="mb-8">
      <ol role="list" class="flex items-center gap-2 text-sm text-[oklch(55%_0_0)]">
        <li><%= link_to "Home", root_path, class: "hover:text-[oklch(21%_0.006_285.885)] transition" %></li>
        <li><span class="text-[oklch(75%_0_0)]">/</span></li>
        <li><%= link_to "Products", products_path, class: "hover:text-[oklch(21%_0.006_285.885)] transition" %></li>
        <li><span class="text-[oklch(75%_0_0)]">/</span></li>
        <li class="text-[oklch(21%_0.006_285.885)]" aria-current="page">Checkout</li>
      </ol>
    </nav>

    <h1 class="text-[28px] lg:text-[32px] font-normal leading-tight text-[oklch(21%_0.006_285.885)] mb-8 lg:mb-10">
      Checkout
    </h1>

    <!-- Two-Column Layout: Payment Left, Summary Right -->
    <div class="flex flex-col lg:grid lg:grid-cols-[1fr_380px] lg:gap-12 xl:gap-16">

      <!-- LEFT: Payment Form -->
      <div class="order-2 lg:order-1"
           data-controller="stripe-checkout"
           data-stripe-checkout-publishable-key-value="<%= Rails.configuration.stripe[:publishable_key] %>"
           data-stripe-checkout-client-secret-value="<%= @payment_intent.client_secret %>"
           data-stripe-checkout-return-url-value="<%= success_checkout_url %>">

        <h2 class="text-sm font-medium uppercase tracking-wider text-[oklch(45%_0_0)] mb-6">Payment</h2>

        <form data-action="submit->stripe-checkout#submit">
          <!-- Loading State -->
          <div data-stripe-checkout-target="loading" class="mb-6">
            <div class="border border-[oklch(88%_0_0)] rounded-lg p-4">
              <div class="animate-pulse space-y-4">
                <div class="h-4 bg-[oklch(94%_0_0)] rounded w-1/3"></div>
                <div class="h-11 bg-[oklch(94%_0_0)] rounded w-full"></div>
                <div class="grid grid-cols-2 gap-4">
                  <div class="h-11 bg-[oklch(94%_0_0)] rounded"></div>
                  <div class="h-11 bg-[oklch(94%_0_0)] rounded"></div>
                </div>
              </div>
            </div>
          </div>

          <!-- Payment Element -->
          <div data-stripe-checkout-target="paymentElement" class="mb-6 hidden">
            <!-- Stripe.js will insert the Payment Element here -->
          </div>

          <!-- Error messages -->
          <div data-stripe-checkout-target="message" class="text-sm text-red-600 mb-4" role="alert"></div>

          <!-- Submit Button -->
          <button
            type="submit"
            data-stripe-checkout-target="submitButton"
            disabled
            class="btn-primary-daisy w-full mt-2"
          >
            <span data-stripe-checkout-target="buttonText">Pay $<%= sprintf("%.2f", @product_price * @quantity) %></span>
            <span data-stripe-checkout-target="spinner" style="display:none">
              <span class="inline-flex items-center gap-2">
                <svg class="animate-spin h-5 w-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                  <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                  <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                </svg>
                Processing...
              </span>
            </span>
          </button>
        </form>

        <!-- Security -->
        <div class="mt-6 pt-6 border-t border-[oklch(92%_0_0)]">
          <div class="flex items-center gap-3 text-sm text-[oklch(45%_0_0)]">
            <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" />
            </svg>
            <span>All transactions are secure and encrypted</span>
          </div>
        </div>
      </div>

      <!-- RIGHT: Order Summary -->
      <div class="order-1 lg:order-2 mb-8 lg:mb-0">
        <div class="lg:sticky lg:top-8">

          <h2 class="text-sm font-medium uppercase tracking-wider text-[oklch(45%_0_0)] mb-6">Order summary</h2>

          <!-- Product Line Item -->
          <div class="flex gap-4 pb-6 border-b border-[oklch(92%_0_0)]">
            <!-- Product Thumbnail -->
            <div class="relative shrink-0 w-16 h-16 rounded-lg bg-gradient-to-br from-[oklch(94%_0.02_260)] to-[oklch(90%_0.03_260)] border border-[oklch(88%_0_0)] flex items-center justify-center">
              <span class="text-2xl">📱</span>
              <% if @quantity > 1 %>
                <span class="absolute -top-2 -right-2 bg-[oklch(45%_0_0)] text-white text-xs w-5 h-5 rounded-full flex items-center justify-center font-medium">
                  <%= @quantity %>
                </span>
              <% end %>
            </div>
            <!-- Product Details -->
            <div class="flex-1 min-w-0">
              <p class="text-sm font-medium text-[oklch(21%_0.006_285.885)] truncate"><%= @product_name %></p>
              <p class="text-sm text-[oklch(55%_0_0)] mt-0.5">Qty: <%= @quantity %></p>
            </div>
            <!-- Price -->
            <div class="shrink-0">
              <p class="text-sm text-[oklch(21%_0.006_285.885)]">$<%= sprintf("%.2f", @product_price) %></p>
            </div>
          </div>

          <!-- Totals -->
          <div class="py-4 space-y-3 border-b border-[oklch(92%_0_0)]">
            <div class="flex justify-between text-sm">
              <span class="text-[oklch(45%_0_0)]">Subtotal</span>
              <span class="text-[oklch(21%_0.006_285.885)]">$<%= sprintf("%.2f", @product_price * @quantity) %></span>
            </div>
            <div class="flex justify-between text-sm">
              <span class="text-[oklch(45%_0_0)]">Shipping</span>
              <span class="text-[oklch(55%_0_0)]">Free</span>
            </div>
          </div>

          <!-- Total -->
          <div class="flex justify-between items-baseline pt-4">
            <span class="text-sm font-medium text-[oklch(21%_0.006_285.885)]">Total</span>
            <span class="text-lg text-[oklch(21%_0.006_285.885)]">$<%= sprintf("%.2f", @product_price * @quantity) %> <span class="text-xs text-[oklch(55%_0_0)] font-normal">USD</span></span>
          </div>

          <!-- Trust Badges -->
          <div class="mt-6 pt-6 border-t border-[oklch(92%_0_0)] space-y-3">
            <div class="flex items-center gap-3 text-sm text-[oklch(45%_0_0)]">
              <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0H21M3.375 14.25V3.375c0-.621.504-1.125 1.125-1.125h9.75c.621 0 1.125.504 1.125 1.125v4.5m3 6.75V10.5a2.25 2.25 0 00-2.25-2.25h-1.5a2.25 2.25 0 00-2.25 2.25v6" />
              </svg>
              <span>Free shipping on orders over $50</span>
            </div>
            <div class="flex items-center gap-3 text-sm text-[oklch(45%_0_0)]">
              <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
              </svg>
              <span>30-day return policy</span>
            </div>
          </div>

        </div>
      </div>

    </div>
  </div>
</div>

