<% content_for :title, "Checkout - Appcessorise" %>

<div class="min-h-screen bg-white">
  <%= render 'shared/navigation' %>

  <div class="mx-auto max-w-[1400px] px-4 sm:px-6 lg:px-12 pt-8 pb-16 lg:pb-24">

    <!-- Two-Column Layout -->
    <div class="flex flex-col lg:grid lg:grid-cols-2 lg:gap-16 xl:gap-24">

      <!-- LEFT: Order Summary -->
      <div class="order-1 mb-10 lg:mb-0">

        <!-- Product card -->
        <div class="flex gap-5 pb-8 border-b border-[#e5e5e5]">
          <!-- Thumbnail placeholder -->
          <div class="shrink-0 w-20 h-20 rounded bg-[#f2f2f2]"></div>
          <!-- Product details -->
          <div class="flex-1 min-w-0">
            <div class="flex items-baseline justify-between gap-3">
              <h2 class="text-[18px] truncate" style="font-family: 'Playfair Display', serif; font-style: italic;">
                <%= @product_name %>
              </h2>
              <span class="text-[18px] text-[#d4542b] shrink-0" style="font-family: 'Playfair Display', serif; font-style: italic;">
                $<%= sprintf("%.2f", @product_price) %>
              </span>
            </div>
            <p class="text-[14px] text-[#999] mt-1">Qty: <%= @quantity %></p>
          </div>
        </div>

        <!-- Totals -->
        <div class="py-5 space-y-3 border-b border-[#e5e5e5]">
          <div class="flex justify-between text-[14px]">
            <span class="text-[#777]">Subtotal</span>
            <span class="text-[#1a1a1a]">$<%= sprintf("%.2f", @product_price * @quantity) %></span>
          </div>
          <div class="flex justify-between text-[14px]">
            <span class="text-[#777]">Shipping</span>
            <span class="text-[#999]">Free</span>
          </div>
        </div>

        <!-- Total -->
        <div class="flex justify-between items-baseline pt-5">
          <span class="text-[15px] font-medium text-[#1a1a1a]">Total</span>
          <span class="text-[20px] text-[#1a1a1a]" style="font-family: 'Playfair Display', serif;">
            $<%= sprintf("%.2f", @product_price * @quantity) %>
            <span class="text-[12px] text-[#999] font-normal" style="font-family: system-ui, sans-serif;">USD</span>
          </span>
        </div>

        <!-- Trust badges -->
        <div class="mt-8 pt-6 border-t border-[#e5e5e5] space-y-3">
          <div class="flex items-center gap-3 text-[13px] text-[#999]">
            <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" />
            </svg>
            <span>All transactions are secure and encrypted</span>
          </div>
          <div class="flex items-center gap-3 text-[13px] text-[#999]">
            <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
            </svg>
            <span>30-day return policy</span>
          </div>
        </div>
      </div>

      <!-- RIGHT: Payment Form -->
      <div class="order-2"
           data-controller="stripe-checkout"
           data-stripe-checkout-publishable-key-value="<%= Rails.configuration.stripe[:publishable_key] %>"
           data-stripe-checkout-client-secret-value="<%= @payment_intent.client_secret %>"
           data-stripe-checkout-return-url-value="<%= success_checkout_url %>">

        <h2 class="text-[14px] font-medium text-[#999] uppercase tracking-wider mb-6">Payment</h2>

        <form data-action="submit->stripe-checkout#submit">
          <!-- Loading State -->
          <div data-stripe-checkout-target="loading" class="mb-6">
            <div class="border border-[#e5e5e5] rounded-lg p-4">
              <div class="animate-pulse space-y-4">
                <div class="h-4 bg-[#f2f2f2] rounded w-1/3"></div>
                <div class="h-11 bg-[#f2f2f2] rounded w-full"></div>
                <div class="grid grid-cols-2 gap-4">
                  <div class="h-11 bg-[#f2f2f2] rounded"></div>
                  <div class="h-11 bg-[#f2f2f2] rounded"></div>
                </div>
              </div>
            </div>
          </div>

          <!-- Payment Element -->
          <div data-stripe-checkout-target="paymentElement" class="mb-6 hidden"></div>

          <!-- Error messages -->
          <div data-stripe-checkout-target="message" class="text-[13px] text-red-600 mb-4" role="alert"></div>

          <!-- Submit Button -->
          <button
            type="submit"
            data-stripe-checkout-target="submitButton"
            disabled
            class="w-full py-3.5 bg-[#1a1a1a] text-white text-[14px] font-medium rounded-full hover:bg-[#333] disabled:opacity-40 disabled:cursor-not-allowed active:translate-y-[0.5px] transition"
          >
            <span data-stripe-checkout-target="buttonText">Pay $<%= sprintf("%.2f", @product_price * @quantity) %></span>
            <span data-stripe-checkout-target="spinner" style="display:none">
              <span class="inline-flex items-center gap-2">
                <svg class="animate-spin h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                  <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                  <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                </svg>
                Processing...
              </span>
            </span>
          </button>
        </form>
      </div>

    </div>
  </div>
</div>
