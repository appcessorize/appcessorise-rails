<!DOCTYPE html>
<html data-theme="light">
  <head>
    <title><%= content_for(:title) || "Admin - Appcessorise" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>

  <body class="bg-gray-100 min-h-screen">
    <!-- Admin Nav -->
    <nav class="bg-gray-900 text-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">
          <div class="flex items-center gap-8">
            <%= link_to "Appcessorise Admin", admin_root_path, class: "font-bold text-lg" %>
            <div class="hidden md:flex items-center gap-1">
              <%= link_to "Dashboard", admin_root_path, class: "px-3 py-2 rounded-md text-sm font-medium hover:bg-gray-700 #{request.path == admin_root_path ? 'bg-gray-700' : ''}" %>
              <%= link_to "Orders", admin_orders_path, class: "px-3 py-2 rounded-md text-sm font-medium hover:bg-gray-700 #{request.path.start_with?('/admin/orders') ? 'bg-gray-700' : ''}" %>
              <%= link_to "Custom Orders", admin_custom_orders_path, class: "px-3 py-2 rounded-md text-sm font-medium hover:bg-gray-700 #{request.path.start_with?('/admin/custom_orders') ? 'bg-gray-700' : ''}" %>
              <%= link_to "Users", admin_users_path, class: "px-3 py-2 rounded-md text-sm font-medium hover:bg-gray-700 #{request.path.start_with?('/admin/users') ? 'bg-gray-700' : ''}" %>
              <%= link_to "Commissions", admin_affiliate_commissions_path, class: "px-3 py-2 rounded-md text-sm font-medium hover:bg-gray-700 #{request.path.start_with?('/admin/affiliate_commissions') ? 'bg-gray-700' : ''}" %>
              <%= link_to "Products", admin_printful_products_path, class: "px-3 py-2 rounded-md text-sm font-medium hover:bg-gray-700 #{request.path.start_with?('/admin/printful_products') ? 'bg-gray-700' : ''}" %>
              <%= link_to "Contacts", admin_contacts_path, class: "px-3 py-2 rounded-md text-sm font-medium hover:bg-gray-700 #{request.path.start_with?('/admin/contacts') ? 'bg-gray-700' : ''}" %>
            </div>
          </div>
          <div class="flex items-center gap-4">
            <%= link_to "View Site", root_path, class: "text-sm text-gray-300 hover:text-white" %>
            <%= button_to "Logout", destroy_user_session_path, method: :delete, class: "text-sm text-gray-300 hover:text-white bg-transparent border-0 cursor-pointer" %>
          </div>
        </div>
      </div>
    </nav>

    <!-- Flash messages -->
    <% if notice %>
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-4">
        <div class="bg-green-50 border border-green-200 text-green-800 px-4 py-3 rounded-lg text-sm"><%= notice %></div>
      </div>
    <% end %>
    <% if alert %>
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-4">
        <div class="bg-red-50 border border-red-200 text-red-800 px-4 py-3 rounded-lg text-sm"><%= alert %></div>
      </div>
    <% end %>

    <!-- Content -->
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <%= yield %>
    </main>
  </body>
</html>
