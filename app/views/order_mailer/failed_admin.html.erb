<div style="max-width: 600px; margin: 0 auto; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; color: #1a1a1a;">
  <div style="background-color: #991b1b; padding: 24px; text-align: center;">
    <h1 style="color: #ffffff; margin: 0; font-size: 24px;">Order Failed at Printful</h1>
  </div>

  <div style="padding: 32px 24px;">
    <p style="font-size: 16px; line-height: 1.6;">An order has failed fulfillment at Printful and requires attention.</p>

    <div style="background-color: #fef2f2; border: 1px solid #fecaca; border-radius: 8px; padding: 16px; margin: 24px 0;">
      <p style="margin: 0; font-size: 14px;"><strong>Order:</strong> <%= @order.order_number %></p>
      <p style="margin: 4px 0 0 0; font-size: 14px;"><strong>Customer:</strong> <%= @order.email %></p>
      <p style="margin: 4px 0 0 0; font-size: 14px;"><strong>Total:</strong> $<%= sprintf("%.2f", @order.total_price) %></p>
      <p style="margin: 4px 0 0 0; font-size: 14px;"><strong>Printful Order ID:</strong> <%= @order.printful_order_id || "N/A" %></p>
      <p style="margin: 4px 0 0 0; font-size: 14px;"><strong>Payment Status:</strong> <%= @order.payment_status %></p>
    </div>

    <% if @order.payment_status == "paid" %>
      <p style="font-size: 16px; line-height: 1.6; color: #991b1b;"><strong>A refund has been automatically initiated for this order.</strong></p>
    <% end %>

    <p style="font-size: 16px; line-height: 1.6;">Please investigate and take appropriate action.</p>
  </div>
</div>
